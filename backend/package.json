{
  "name": "glocalizer-backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "TMPDIR=/tmp tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:check": "npm run build && tsc -p tsconfig.scripts.json && node dist/scripts/check-supabase.js",
    "db:migrate": "npm run build && tsc -p tsconfig.scripts.json && node dist/scripts/run-migrations.js",
    "dataset:generate": "python3 python/generate_synthetic_ocr_dataset.py --count 1000",
    "dataset:split": "python3 python/prepare_ocr_training_splits.py",
    "benchmark:ocr": "python3 python/benchmark_ocr.py --manifest benchmarks/ocr/manifest.local.json",
    "ocr:accelerator-check": "python3 python/check_ocr_accelerators.py",
    "ocr:windows-npu-check": "cmd.exe /c py -3 python/windows_openvino_npu_probe.py",
    "ocr:npu:export": "python3 python/export_ocr_models_to_onnx.py",
    "ocr:npu:benchmark-rec": "cmd.exe /c py -3 python/windows_openvino_npu_probe.py --model training/ocr/openvino/korean_PP-OCRv5_mobile_rec.onnx --static-width 640 --runs 20",
    "ocr:npu:benchmark-det": "cmd.exe /c py -3 python/windows_openvino_npu_probe.py --model training/ocr/openvino/PP-OCRv5_mobile_det.onnx --static-shape 1,3,1280,1280 --runs 10",
    "ocr:npu:recognize": "cmd.exe /c py -3 python/windows_openvino_ocr.py",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
