# Server
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# OCR + Translation providers
OCR_PROVIDER=paddle
# 실험용: 사용자 결과에는 반영하지 않고 NPU 측정 로그만 남깁니다.
OCR_SHADOW_PROVIDER=none
OCR_SHADOW_MAX_VARIANTS=2
OCR_PYTHON_EXECUTABLE=python3
# Windows Intel NPU를 사용할 때: OCR_PROVIDER=openvino-npu 또는 OCR_SHADOW_PROVIDER=openvino-npu
OCR_WINDOWS_PYTHON=py
OCR_TIMEOUT_MS=90000
OCR_IMAGE_MAX_DIMENSION=1280
# 선택 사항: Paddle 다중 합의가 약할 때만 Gemini Vision으로 재판정합니다.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
VISION_PROVIDER=groq
GROQ_VISION_MODEL=qwen/qwen3.6-27b
VISION_TIMEOUT_MS=25000
TRANSLATION_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
TRANSLATION_TIMEOUT_MS=15000
AI_CONCURRENCY=4
AI_MAX_RETRIES=1
IMAGE_PREPROCESS_CONCURRENCY=4
CLEANUP_CONCURRENCY=4

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=glocalizer-private

# Project
PROJECT_TOKEN_SECRET=
PROJECT_EXPIRY_HOURS=24
MAX_FILES_PER_PROJECT=20
MAX_FILE_SIZE_MB=5
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096
MAX_REGENERATE_COUNT=3

# Worker / Logging
WORKER_POLL_INTERVAL_MS=2000
CLEANUP_SWEEP_INTERVAL_MS=1800000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
LOG_LEVEL=info
