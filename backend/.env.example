# Server
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# NVIDIA
# NVIDIA_API_KEY는 아래 3개의 개별 키가 없을 때 쓰는 공용 폴백이다.
NVIDIA_API_KEY=
NVIDIA_OCR_API_KEY=
NVIDIA_TRANSLATION_API_KEY=
NVIDIA_REVIEW_API_KEY=

NVIDIA_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# 예: https://ai.api.nvidia.com/v1/cv/nvidia/nemotron-ocr-v2 (모델별 고정 invoke URL, 도메인 루트 아님)
NVIDIA_OCR_BASE_URL=
NVIDIA_OCR_MODEL=nvidia/nemotron-ocr-v2
NVIDIA_TRANSLATION_MODEL=z-ai/glm-5.2
NVIDIA_REVIEW_MODEL=deepseek-ai/deepseek-v4-pro

# NVIDIA 응답이 느릴 때(무료/프리뷰 티어 큐잉) 요청이 무한정 걸리지 않도록 하는 타임아웃/재시도 설정
NVIDIA_REQUEST_TIMEOUT_MS=300000
MAX_TRANSLATION_RETRIES=2
# 프로젝트 안 이미지 여러 장을 동시에 몇 개까지 처리할지 (OCR/번역 단계)
AI_CONCURRENCY=2

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=glocalizer-private

# Project
PROJECT_EXPIRY_HOURS=24
MAX_FILES_PER_PROJECT=20
MAX_FILE_SIZE_MB=5
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# AI
OCR_REVIEW_THRESHOLD=0.85
MAX_REGENERATE_COUNT=3

# Worker / 정리 작업
WORKER_POLL_INTERVAL_MS=2000
CLEANUP_SWEEP_INTERVAL_MS=1800000

# Security
PROJECT_TOKEN_SECRET=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Logging
LOG_LEVEL=info
